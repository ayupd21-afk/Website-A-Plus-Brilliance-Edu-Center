            padding: 100px 20px 80px;
            text-align: center;
            position: relative;
        }

        .badge-top {
            background-color: var(--accent);
            color: var(--primary);
            padding: 6px 18px;
            border-radius: 50px;
            font-weight: 700;
            font-size: 0.85rem;
            display: inline-block;
            margin-bottom: 20px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        header h1 {
            font-size: 3rem;
            font-weight: 700;
            margin-bottom: 15px;
            letter-spacing: -1px;
        }

        header p {
            font-size: 1.2rem;
            opacity: 0.9;
            max-width: 700px;
            margin: 0 auto 30px;
            font-weight: 300;
        }

        .contact-bar {
            background: rgba(255, 255, 255, 0.15);
            padding: 15px 25px;
            border-radius: 50px;
            display: inline-flex;
            gap: 25px;
            flex-wrap: wrap;
            justify-content: center;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .contact-item {
            color: var(--white);
            text-decoration: none;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* Container Layout */
        .container {
            max-width: 1140px;
            margin: 0 auto;
            padding: 80px 20px;
        }

        section {
            margin-bottom: 60px;
        }

        .section-title {
            text-align: center;
            font-size: 2.2rem;
            color: var(--primary);
            margin-bottom: 45px;
        }

        .section-title span {
            display: block;
            width: 70px;
            height: 4px;
            background: var(--accent);
            margin: 10px auto;
            border-radius: 2px;
        }

        /* Grid Blocks */
        .grid-2 {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 30px;
        }

        .grid-3 {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 25px;
        }

        /* Info & Feature Cards */
        .card-info {
            background: var(--bg-light);
            padding: 40px;
            border-radius: 15px;
            border-top: 5px solid var(--primary);
            transition: 0.3s;
        }

        .card-info h3 {
            color: var(--primary);
            margin-bottom: 15px;
            font-size: 1.5rem;
        }

        .card-feature {
            background: var(--white);
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);

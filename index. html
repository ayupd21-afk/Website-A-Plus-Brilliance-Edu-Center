    <style>
        :root {
            --primary: #1e3a8a; /* Navy Blue */
            --primary-light: #3b82f6; /* Blue */
            --accent: #f59e0b; /* Gold/Amber */
            --text-dark: #1f2937;
            --text-light: #4b5563;
            --bg-light: #f8fafc;
            --white: #ffffff;
            --success: #22c55e;
        }

        * {
